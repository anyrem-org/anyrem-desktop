{
  "name": "anyrem-desktop",
  "version": "0.1.3",
  "description": "AnyRem desktop client",
  "author": "AnyRem",
  "homepage": "https://anyrem.anzita.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/anyrem-org/anyrem-desktop.git"
  },
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"pnpm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "icons": "node scripts/generate-icons.mjs",
    "predist": "pnpm icons",
    "dist": "pnpm build && electron-builder",
    "dist:linux": "pnpm build && electron-builder --linux",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:publish": "pnpm build && electron-builder --publish always",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@tanstack/react-query": "^5.80.7",
    "@tiptap/extension-code-block-lowlight": "^2.26.1",
    "@tiptap/extension-highlight": "2.26.1",
    "@tiptap/extension-link": "2.26.1",
    "@tiptap/extension-placeholder": "2.26.1",
    "@tiptap/extension-table": "2.26.1",
    "@tiptap/extension-table-cell": "2.26.1",
    "@tiptap/extension-table-header": "2.26.1",
    "@tiptap/extension-table-row": "2.26.1",
    "@tiptap/extension-text-align": "2.26.1",
    "@tiptap/extension-underline": "2.26.1",
    "@tiptap/react": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "@xyflow/react": "^12.8.1",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lowlight": "3.3.0",
    "lucide-react": "^0.515.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "6.30.4",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "41.7.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.4",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "wait-on": "8.0.3"
  }
}
